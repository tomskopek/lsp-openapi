{
  "name": "lsp-openapi",
  "displayName": "OpenAPI LSP",
  "description": "Go-to-definition for OpenAPI YAML specs (operationId and $ref).",
  "version": "0.1.0",
  "publisher": "tomskopek",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomskopek/lsp-openapi"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:yaml"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "copy-server": "cp ../server.py ./server.py",
    "compile": "tsc -p ./",
    "vscode:prepublish": "npm run copy-server && npm run compile",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.4.0"
  }
}
